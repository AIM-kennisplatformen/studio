# ============================================================
# Test Environment Configuration (.env.test) — SAMPLE
# ============================================================
# Copy this file to .env.test and fill in the secrets.
# Used by `pixi run qava_test` to run BDD integration tests.
#
# All containers and scripts will use .env.test instead of .env
# so that tests always run with deterministic settings.
# ============================================================

# ── Zotero (MCP Paper Search) ──────────────────────────────
ZOTERO_API_KEY=""
ZOTERO_LIBRARY_ID=""
ZOTERO_COLLECTION_ID=""

# ── Qdrant ──────────────────────────────────────────────────
QDRANT_URL="127.0.0.1"
QDRANT_PORT=6333

# ── Backend ─────────────────────────────────────────────────
BACKEND_BASE_URL=http://localhost:10090
VITE_BACKEND_BASE_URL=http://localhost:10090

# ── LLM Worker ──────────────────────────────────────────────
LLM_WORKER_URL=http://localhost
LLM_WORKER_PORT=7000

# ── Authentik ───────────────────────────────────────────────
# Generate these using:
#   openssl rand -base64 60   (for AUTHENTIK_SECRET_KEY)
#   openssl rand -base64 36   (for PG_PASS)
AUTHENTIK_SECRET_KEY=
PG_PASS=

# ── Authentik OAuth Application ─────────────────────────────
# These must match with setup_authentik.sh. (dont use these example values in production only in development and testing)
OAUTH_CLIENT_ID=9h9FmtG9XSqvm4zyUVqIzpV3q0p2EVG5MsGJPoa2
OAUTH_CLIENT_SECRET=Wfx8Z7FAxFB9g5t7BJRmNTsOUYuXzXIIPc8KTNpkyv5jO34Ia4q3uSYmQwoMAgMpMpoOz5AO1qraJBfxLOy2zxskp7vXsLTlrzatLoECnDW6YmDBvjuwwM92QyUG09Db
OAUTH_DISCOVERY_URL=http://host.docker.internal:9000/application/o/studio/.well-known/openid-configuration

# ── Langfuse (optional) ────────────────────────────────────
#LANGFUSE_SECRET_KEY=""
#LANGFUSE_PUBLIC_KEY=""
#LANGFUSE_HOST=""

# ── LLM / AI Provider ──────────────────────────────────────
# Integration tests call the real LLM — provide valid credentials.
OPENAI_HOST=
OPENAI_API_KEY=
LLM_MODEL=

# ── MCP Tool Config ────────────────────────────────────────
MCP_TOOL_CONFIG_PATH=scepa_tools.json
