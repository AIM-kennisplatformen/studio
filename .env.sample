# Setup Zotero for MCP_SERVER Paper search
# API_KEY can be generated online from user profile webpage in zotero
# LIBRARY_ID is the number that is within url when clicking library in online explorer: 
#			 <https://www.zotero.org/groups/<library_id>/<library_name>/library>
# COLLECTION_ID is the collection slug (8 characters) within url when clicking collection of library in online explorer: 
#              <https://www.zotero.org/groups/<library_id>/<library_name>/collections/<collection_id>/collection> 

# ZOTERO_API_KEY=""
# ZOTERO_LIBRARY_ID=""
# ZOTERO_COLLECTION_ID=""

# Setup Authentik
# Authentik needs secret key and password for protecting it's databases and sessions
#
# You need to generate these using the openssl command
# Generate the PG_PASS using: `openssl rand -base64 36`
# Generate the AUTHENTIK_SECRET_KEY using: `openssl rand -base64 60`
#
#AUTHENTIK_SECRET_KEY=abcdefghijklmnopqrstuv....
#PG_PASS=abcdefghijklmnopqrstuv....

# Setup Backend_server URL
#BACKEND_BASE_URL=http://kg.localhost:8090

# Setup LLM Worker URL
#LLM_WORKER_URL=

# Authentik OAUTH Application
#OAUTH_CLIENT_ID=
#OAUTH_CLIENT_SECRET=
#OAUTH_DISCOVERY_URL= https://<authentik_url>/application/o/<application_name>/.well-known/openid-configuration

# Langfuse
#LANGFUSE_SECRET_KEY=""
#LANGFUSE_PUBLIC_KEY=""
#LANGFUSE_HOST=""